<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- TREE -->
    <record id="view_khau_hao_tree" model="ir.ui.view">
      <field name="name">khau_hao.tree</field>
      <field name="model">khau_hao</field>
      <field name="arch" type="xml">
        <tree string="Khấu hao">
          <field name="tai_san_id"/>
          <field name="ngay_tinh"/>
          <field name="ngay_bat_dau"/>
          <field name="so_thang_khau_hao"/>
          <field name="nguyen_gia"/>
          <field name="gia_tri_con_lai"/>
        </tree>
      </field>
    </record>

    <!-- FORM -->
    <record id="view_khau_hao_form" model="ir.ui.view">
      <field name="name">khau_hao.form</field>
      <field name="model">khau_hao</field>
      <field name="arch" type="xml">
        <form string="Khấu hao">
          <sheet>
            <group col="4">
              <!-- chỉ cho chọn lúc tạo, tạo xong thì khoá -->
              <field name="tai_san_id" attrs="{'readonly':[('id','!=',False)]}"/>

              <field name="ngay_tinh"/>
              <field name="ngay_bat_dau"/>
              <field name="so_thang_khau_hao"/>

              <field name="nguyen_gia" readonly="1"/>
              <field name="gia_tri_con_lai" readonly="1"/>

              <field name="ghi_chu"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- SEARCH -->
    <record id="view_khau_hao_search" model="ir.ui.view">
      <field name="name">khau_hao.search</field>
      <field name="model">khau_hao</field>
      <field name="arch" type="xml">
        <search string="Tìm kiếm khấu hao">
          <field name="tai_san_id"/>
          <field name="ngay_tinh"/>
          <field name="ngay_bat_dau"/>
          <separator/>
          <filter string="Hôm nay" name="kh_hom_nay"
                  domain="[('ngay_tinh','=',context_today())]"/>
        </search>
      </field>
    </record>

    <!-- ACTION -->
    <record id="action_khau_hao" model="ir.actions.act_window">
      <field name="name">Khấu hao</field>
      <field name="res_model">khau_hao</field>
      <field name="view_mode">tree,form</field>
      <field name="search_view_id" ref="view_khau_hao_search"/>
    </record>

  </data>
</odoo>
